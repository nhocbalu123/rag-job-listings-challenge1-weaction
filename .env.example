# Copy this file to .env and fill in your values
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ragdb

GEMINI_API_KEY=your_ai_studio_key
EMBEDDING_MODEL=BAAI/bge-m3
